# Ollama (既に起動している前提)
OLLAMA_BASE_URL=http://localhost:11434
CHAT_MODEL=gpt-oss:20b
EMBED_MODEL=nomic-embed-text

# gpt-oss の reasoning(思考)レベル: low | medium | high
REASONING_EFFORT=medium
# gpt-oss は 128K 対応だが Ollama は明示しないと黙って切り詰める
NUM_CTX=8192

# 評価→再計画ループの最大反復回数
MAX_ITERATIONS=2

# nomic-embed-text の埋め込み次元(必須・固定)
EMBED_DIMS=768

# CORS 許可する Vite dev サーバのオリジン
FRONTEND_ORIGIN=http://localhost:5173
